# Copy this file to .env and fill in values before running with Docker Compose

# Anthropic Claude API key (required for Claude-based features)
ANTHROPIC_API_KEY=

# OpenAI API key (optional; required for some TTS/voice features)
OPENAI_API_KEY=

# JWT secret for signing tokens
JWT_SECRET=replace-with-a-secure-random-string

# Database URL (MariaDB in Docker by default)
# Format: mysql+pymysql://user:password@host:port/database
DATABASE_URL=mysql+pymysql://convora:convora_password@mariadb:3306/convora
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
OPENAI_API_KEY="sk-..."  # Required for voice mode (TTS synthesis)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
DATABASE_URL="sqlite:///./convora.db"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080